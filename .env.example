EMBEDDING_HOST=127.0.0.1
EMBEDDING_PORT=8100

EMBEDDING_BACKEND=sentence-transformers
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=auto
EMBEDDING_PRELOAD=true

EMBEDDING_BATCH_SIZE=16
EMBEDDING_MAX_BATCH_SIZE=32
EMBEDDING_MAX_INPUT_CHARS=12000
EMBEDDING_MAX_LENGTH=8192
EMBEDDING_NORMALIZE=true
EMBEDDING_RECOMMENDED_DISTANCE=Cosine
EMBEDDING_MODEL_CACHE_DIR=./data/models
EMBEDDING_ENCODE_CONCURRENCY=1

EMBEDDING_API_KEY=
EMBEDDING_REQUIRE_API_KEY=false
EMBEDDING_REQUIRE_API_KEY_FOR_READY=false

LOG_LEVEL=INFO

